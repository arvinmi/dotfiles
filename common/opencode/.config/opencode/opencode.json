{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "autoupdate": "notify",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          }
        },
        "gpt-5.3-codex": {
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": { "baseURL": "http://127.0.0.1:1234/v1" }
    }
  },
  "agent": {
    "plan": {
      "reasoningEffort": "high"
    },
    "build": {
      "steps": 50
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 39000
  },
  "plugin": ["opencode-quotas"],
  "mcp": {
    "c7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
